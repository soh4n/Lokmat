# LokMat API — Environment Variables
# Copy to .env and fill in values. NEVER commit the real .env file.

# App
APP_NAME=LokMat API
APP_VERSION=1.0.0
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# GCP Project
GCP_PROJECT_ID=lokmat-495121

# Auth — Firebase (set to true in production with Cloud Run)
FIREBASE_AUTH_ENABLED=false

# Legacy JWT (used when FIREBASE_AUTH_ENABLED=false)
JWT_SECRET=lokmat-dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# Gemini API (Google AI Studio / Vertex AI)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL_FLASH=gemini-2.5-flash
GEMINI_MODEL_PRO=gemini-2.5-pro
GEMINI_MAX_OUTPUT_TOKENS=1024
GEMINI_TEMPERATURE=0.7

# Database — Cloud SQL (PostgreSQL)
# Local: sqlite+aiosqlite:///./lokmat.db
# Docker: postgresql+asyncpg://lokmat_user:lokmat_dev_password@db:5432/lokmat
# Production: injected via Secret Manager
DATABASE_URL=sqlite+aiosqlite:///./lokmat.db

# Redis — Memorystore
# Local: leave empty for in-memory fallback
# Docker: redis://redis:6379/0
REDIS_URL=

# Cloud Storage (GCS)
GCS_BUCKET=
GCS_VOTER_SLIP_PREFIX=voter-slips/

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
INFERENCE_RATE_LIMIT_PER_MINUTE=10

# Token Budget
MAX_CONTEXT_TOKENS=8000
WARN_THRESHOLD_TOKENS=50000
